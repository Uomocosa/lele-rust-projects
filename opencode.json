{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "model": "opencode-go/deepseek-v4-flash",
  "instructions": [
    "~/.config/opencode/skills/lele-syntax-rs/SKILL.md",
    "~/.config/opencode/skills/opencode-git-workflow/SKILL.md"
  ],
  "permission": {
    "external_directory": {
      "/**": "allow"
    },
    "skill": {
      "*": "deny",
      "opencode-*": "allow",
      "*-rs": "allow",
      "bevy": "allow",
      "libp2p-rust": "allow"
    }
  },
  "provider": {
    "opencode-go": {
      "models": {
        "deepseek-v4-flash": {
          "variants": {
            "high": {
              "reasoningEffort": "high"
            }
          }
        }
      }
    }
  }
}
